{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  }
                },
                "required": ["name"]
              }
            ]
          }
        },
        "appImage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "registry": {
              "type": "string"
            },
            "tag": {
              "type": "string"
            },
            "pullPolicy": {
              "$ref": "#/definitions/pullPolicy"
            }
          }
        },
        "caCertificate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "existingConfigMap": {
              "type": "string"
            },
            "key": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": "string"
            }
          }
        },
        "defaultResources": {
          "$ref": "#/definitions/resources"
        },
        "nodeSelector": {
          "$ref": "#/definitions/nodeSelector"
        },
        "tolerations": {
          "$ref": "#/definitions/tolerations"
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        }
      }
    },
    "infisical": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "projectId": {
          "type": "string"
        },
        "environmentSlug": {
          "type": "string"
        },
        "secretPathPrefix": {
          "type": "string"
        },
        "refreshInterval": {
          "type": "string"
        },
        "instantUpdates": {
          "type": "boolean"
        },
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create": {
              "type": "boolean"
            },
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            },
            "address": {
              "type": "string"
            }
          }
        },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create": {
              "type": "boolean"
            },
            "name": {
              "type": "string"
            },
            "namespace": {
              "type": "string"
            },
            "method": {
              "type": "string",
              "enum": ["kubernetes", "universal"]
            },
            "kubernetes": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "identityIdSecretRef": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "namespace": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    }
                  },
                  "required": ["name", "key"]
                },
                "serviceAccount": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "create": {
                      "type": "boolean"
                    },
                    "name": {
                      "type": "string"
                    },
                    "namespace": {
                      "type": "string"
                    }
                  },
                  "required": ["name"]
                },
                "serviceAccountTokenAudiences": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "universal": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "credentialsSecretRef": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "namespace": {
                      "type": "string"
                    },
                    "clientIdKey": {
                      "type": "string"
                    },
                    "clientSecretKey": {
                      "type": "string"
                    }
                  },
                  "required": ["name", "clientIdKey", "clientSecretKey"]
                }
              }
            }
          },
          "required": ["method"],
          "allOf": [
            {
              "if": {
                "properties": {
                  "method": {
                    "const": "kubernetes"
                  }
                }
              },
              "then": {
                "required": ["kubernetes"]
              }
            },
            {
              "if": {
                "properties": {
                  "method": {
                    "const": "universal"
                  }
                }
              },
              "then": {
                "required": ["universal"]
              }
            }
          ]
        },
        "managedSecrets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create": {
              "type": "boolean"
            },
            "creationPolicy": {
              "type": "string",
              "enum": ["Owner", "Orphan", "Merge", "None"]
            }
          },
          "allOf": [
            {
              "if": {
                "required": ["create"],
                "properties": {
                  "create": {
                    "const": true
                  }
                }
              },
              "then": {
                "required": ["creationPolicy"]
              }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["enabled"],
            "properties": {
              "enabled": {
                "const": true
              }
            }
          },
          "then": {
            "required": ["projectId"],
            "properties": {
              "projectId": {
                "type": "string",
                "minLength": 1
              },
              "connection": {
                "type": "object",
                "properties": {
                  "create": {
                    "type": "boolean"
                  },
                  "address": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "required": ["create"],
                      "properties": {
                        "create": {
                          "const": true
                        }
                      }
                    },
                    "then": {
                      "required": ["address"]
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "className": {
          "type": "string"
        },
        "controllerNamespace": {
          "type": "string",
          "minLength": 1
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "secretName": {
                "type": "string"
              },
              "hosts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": {
                "type": "string"
              },
              "serviceName": {
                "type": "string"
              },
              "servicePort": {
                "oneOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "path": {
                "type": "string"
              },
              "pathType": {
                "type": "string",
                "enum": ["Exact", "Prefix", "ImplementationSpecific"]
              }
            },
            "required": ["host", "serviceName", "servicePort"]
          }
        }
      }
    },
    "services": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sheetAuth": {
          "$ref": "#/definitions/appService"
        },
        "sheetApis": {
          "$ref": "#/definitions/appService"
        },
        "sheetBot": {
          "$ref": "#/definitions/appService"
        },
        "sheetWorkflows": {
          "$ref": "#/definitions/appService"
        },
        "sheetWorkflowsRunner": {
          "$ref": "#/definitions/appService"
        },
        "sheetDbServer": {
          "$ref": "#/definitions/appService"
        },
        "sheetIngressServer": {
          "$ref": "#/definitions/appService"
        },
        "sheetWeb": {
          "$ref": "#/definitions/appService"
        }
      }
    },
    "zeroCache": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicas": {
          "type": "integer",
          "minimum": 0
        },
        "nameOverride": {
          "type": "string"
        },
        "serviceNameOverride": {
          "type": "string"
        },
        "image": {
          "$ref": "#/definitions/image"
        },
        "resources": {
          "$ref": "#/definitions/resources"
        },
        "nodeSelector": {
          "$ref": "#/definitions/nodeSelector"
        },
        "tolerations": {
          "$ref": "#/definitions/tolerations"
        },
        "envoy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "configMapNameOverride": {
              "type": "string"
            },
            "tokenRefreshIntervalSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "image": {
              "$ref": "#/definitions/image"
            },
            "resources": {
              "$ref": "#/definitions/resources"
            }
          }
        },
        "secretRef": {
          "$ref": "#/definitions/secretRef"
        },
        "persistence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "storageClassName": {
              "type": "string"
            },
            "size": {
              "type": "string"
            },
            "existingVolumeName": {
              "type": "string"
            }
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prometheusNamespace": {
          "type": "string",
          "minLength": 1
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "releaseLabel": {
              "type": "string",
              "minLength": 1
            }
          },
          "allOf": [
            {
              "if": {
                "required": ["enabled"],
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              },
              "then": {
                "required": ["releaseLabel"]
              }
            }
          ]
        }
      }
    },
    "networkPolicies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxUnavailable": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      }
    }
  },
  "definitions": {
    "pullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never", ""]
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "$ref": "#/definitions/pullPolicy"
        }
      }
    },
    "appService": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "serviceNameOverride": {
          "type": "string"
        },
        "nameOverride": {
          "type": "string"
        },
        "image": {
          "$ref": "#/definitions/image"
        },
        "replicas": {
          "type": "integer",
          "minimum": 0
        },
        "secretRef": {
          "$ref": "#/definitions/secretRef"
        },
        "googleServiceAccountSecretRef": {
          "$ref": "#/definitions/secretRefWithKey"
        },
        "seedTrustedOAuthClients": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "backoffLimit": {
              "type": "integer",
              "minimum": 0
            },
            "activeDeadlineSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "ttlSecondsAfterFinished": {
              "type": "integer",
              "minimum": 0
            },
            "resources": {
              "$ref": "#/definitions/resources"
            },
            "nodeSelector": {
              "$ref": "#/definitions/nodeSelector"
            },
            "tolerations": {
              "$ref": "#/definitions/tolerations"
            }
          }
        },
        "nodeSelector": {
          "$ref": "#/definitions/nodeSelector"
        },
        "tolerations": {
          "$ref": "#/definitions/tolerations"
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string"
            },
            "interval": {
              "type": "string"
            },
            "scrapeTimeout": {
              "type": "string"
            },
            "scheme": {
              "type": "string"
            },
            "tlsConfig": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "resources": {
          "$ref": "#/definitions/resources"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "key": {
            "type": "string"
          },
          "operator": {
            "type": "string",
            "enum": ["Exists", "Equal"]
          },
          "value": {
            "type": "string"
          },
          "effect": {
            "type": "string",
            "enum": ["NoSchedule", "PreferNoSchedule", "NoExecute"]
          },
          "tolerationSeconds": {
            "type": ["integer", "null"]
          }
        }
      }
    },
    "secretRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "secretRefWithKey": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "key": {
          "type": "string"
        }
      }
    }
  }
}
