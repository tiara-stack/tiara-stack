{
  "name": "tiara-stack-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "vp run -r format",
    "lint": "vp run -r lint",
    "test": "vp run -F './packages/*' test",
    "checks": "status=0; vp run -w format || status=$?; vp run -w lint || status=$?; vp run -w test || status=$?; exit $status",
    "format:apply": "vp run -r format:apply",
    "build": "vp run -r --concurrency-limit 1 build",
    "compose:generate-secrets": "tsx deploy/compose/scripts/generate-secrets.ts --no-overwrite",
    "compose:migrate-sheet-db": "tsx deploy/compose/scripts/migrate-sheet-db.ts",
    "prepare": "vp config"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@rocicorp/zero-sqlite3",
      "better-sqlite3"
    ],
    "overrides": {
      "better-auth": "1.6.16"
    },
    "patchedDependencies": {
      "better-auth@1.6.16": "patches/better-auth@1.6.16.patch"
    }
  }
}
