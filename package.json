{
  "name": "tiara-stack-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "vp run -r format",
    "lint": "vp run -r lint",
    "test": "pnpm -r --if-present --filter './packages/*' test",
    "check:tsc-build": "tsc -b tsconfig.build.json --pretty false",
    "lint:effect": "pnpm --filter effect-lint build && effect-lint --project 'packages/*/tsconfig.json' --format pretty",
    "checks": "pnpm format && pnpm lint && pnpm check:tsc-build && pnpm lint:effect && pnpm test",
    "format:apply": "vp run -r format:apply",
    "build": "vp run -r build",
    "compose:generate-secrets": "tsx deploy/compose/scripts/generate-secrets.ts --no-overwrite",
    "compose:migrate-sheet-db": "tsx deploy/compose/scripts/migrate-sheet-db.ts",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "@types/node": "catalog:",
    "effect": "catalog:",
    "effect-lint": "workspace:*",
    "tsx": "catalog:",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@rocicorp/zero-sqlite3",
      "better-sqlite3"
    ],
    "overrides": {
      "better-auth": "1.6.16"
    },
    "patchedDependencies": {
      "better-auth@1.6.16": "patches/better-auth@1.6.16.patch"
    }
  }
}
