{
  "extends": "../../tsconfig.browser.json",
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts"],
  "exclude": ["node_modules", "dist", ".output", ".ts-out"],
  "compilerOptions": {
    "outDir": "./.ts-out",
    "rootDir": ".",
    "tsBuildInfoFile": "./.ts-out/.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "~/*": ["./src/*"],
      "@/*": ["./src/*"],
      "typhoon-core": ["../typhoon-core/src/index.ts"],
      "typhoon-core/*": ["../typhoon-core/src/*"]
    }
  },
  "references": [
    {
      "path": "../typhoon-core"
    },
    {
      "path": "../tooling-config"
    }
  ]
}
