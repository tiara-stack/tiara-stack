{
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts", "src/**/*.mts"],
  "exclude": ["src/**/*.test.ts"],
  "compilerOptions": {
    "allowJs": false,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "incremental": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./.tsbuildinfo"
  }
}
