{
  "name": "sheet-db-server",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "",
  "files": [
    "./dist/**"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*/index.d.mts",
      "default": "./dist/*/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "vp lint src",
    "check:effect-lsp": "NODE_OPTIONS='--max-old-space-size=4096' effect-language-service diagnostics --project tsconfig.json --format text --lspconfig '{}'",
    "build": "vp pack && tar -acf dist.tar.zst ./dist"
  },
  "dependencies": {
    "@effect/opentelemetry": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@opentelemetry/exporter-prometheus": "^0.207.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.207.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@rocicorp/zero": "^0.25.9",
    "drizzle-orm": "^0.45.1",
    "effect": "catalog:",
    "postgres": "^3.4.7",
    "sheet-db-schema": "workspace:*",
    "typhoon-core": "workspace:*",
    "typhoon-zero": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.16.0",
    "@typescript/native-preview": "latest",
    "glob": "^11.0.1",
    "pathe": "^2.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
