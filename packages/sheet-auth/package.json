{
  "name": "sheet-auth",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "development": "./src/client.ts",
      "default": "./dist/client.mjs"
    },
    "./model": {
      "types": "./dist/model.d.mts",
      "default": "./dist/model.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "default": "./dist/schema.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "default": "./dist/server.mjs"
    },
    "./oauth-resource-authorization": {
      "types": "./dist/oauth-resource-authorization.d.mts",
      "development": "./src/oauth-resource-authorization.ts",
      "default": "./dist/oauth-resource-authorization.mjs"
    },
    "./oauth": {
      "types": "./dist/oauth.d.mts",
      "development": "./src/oauth.ts",
      "default": "./dist/oauth.mjs"
    },
    "./plugins/sheet-oauth/client": {
      "types": "./dist/plugins/sheet-oauth/client.d.mts",
      "development": "./src/plugins/sheet-oauth/client.ts",
      "default": "./dist/plugins/sheet-oauth/client.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "vp lint src",
    "test": "vp test run --passWithNoTests",
    "test:watch": "vp test",
    "build": "vp pack && tar -acf dist.tar.zst ./dist",
    "seed:trusted-oauth-clients": "tsx scripts/seed-trusted-oauth-clients.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.16",
    "@effect/platform-node": "catalog:",
    "@hono/node-server": "^1.19.9",
    "@opentelemetry/exporter-prometheus": "^0.207.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.207.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "better-auth": "^1.6.16",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.11.9",
    "ioredis": "^5.9.3",
    "jose": "^6.1.3",
    "postgres": "^3.4.7",
    "typhoon-core": "workspace:*",
    "unstorage": "^1.17.4"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "latest",
    "drizzle-kit": "^0.31.4",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@better-fetch/fetch": "1.2.2",
    "@effect/opentelemetry": "catalog:",
    "@standard-schema/spec": "^1.0.0",
    "effect": "catalog:",
    "nanostores": "^1.1.0"
  }
}
