{
  "extends": "../../tsconfig.apps-script.json",
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts"],
  "exclude": ["node_modules", "dist", ".output", ".ts-out"],
  "compilerOptions": {
    "outDir": "./.ts-out",
    "rootDir": ".",
    "tsBuildInfoFile": "./.ts-out/.tsbuildinfo",
    "paths": {
      "*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "effect-platform-apps-script": ["../effect-platform-apps-script/src/index.ts"],
      "effect-platform-apps-script/*": ["../effect-platform-apps-script/src/*"],
      "sheet-ingress-api": ["../sheet-ingress-api/src/index.ts"],
      "sheet-ingress-api/*": ["../sheet-ingress-api/src/*"],
      "typhoon-core": ["../typhoon-core/src/index.ts"],
      "typhoon-core/*": ["../typhoon-core/src/*"]
    }
  },
  "references": [
    {
      "path": "../effect-platform-apps-script"
    },
    {
      "path": "../sheet-ingress-api"
    },
    {
      "path": "../typhoon-core"
    }
  ]
}
