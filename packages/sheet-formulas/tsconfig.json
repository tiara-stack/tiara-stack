{
  "include": ["**/*.ts", "**/*.tsx", "*.ts", "*.tsx"],
  "exclude": ["./dist"],
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["google-apps-script"],
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "effect-platform-apps-script": ["../effect-platform-apps-script/src/index.ts"],
      "effect-platform-apps-script/*": ["../effect-platform-apps-script/src/*"],
      "sheet-ingress-api": ["../sheet-ingress-api/src/index.ts"],
      "sheet-ingress-api/*": ["../sheet-ingress-api/src/*"],
      "*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"]
    }
  }
}
