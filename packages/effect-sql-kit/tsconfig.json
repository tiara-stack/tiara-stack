{
  "include": ["**/*.ts", "*.ts"],
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "effect-sql-kit": ["./src/index.ts"],
      "vitest": ["./node_modules/vitest"],
      "*": ["./*"]
    }
  }
}
