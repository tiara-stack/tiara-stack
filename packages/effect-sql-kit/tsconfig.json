{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts"],
  "exclude": ["node_modules", "dist", ".output", ".ts-out"],
  "compilerOptions": {
    "outDir": "./.ts-out",
    "rootDir": ".",
    "tsBuildInfoFile": "./.ts-out/.tsbuildinfo",
    "paths": {
      "*": ["./*"],
      "effect-sql-kit": ["./src/index.ts"],
      "effect-sql-schema": ["../effect-sql-schema/src/index.mts"],
      "effect-sql-schema/snapshot": ["../effect-sql-schema/src/snapshot.mts"],
      "effect-sql-schema/*": ["../effect-sql-schema/src/*"]
    }
  },
  "references": [
    {
      "path": "../effect-sql-schema"
    }
  ]
}
