{
  "extends": "../../tsconfig.browser.json",
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts"],
  "exclude": ["node_modules", "dist", ".output", ".ts-out"],
  "compilerOptions": {
    "outDir": "./.ts-out",
    "rootDir": ".",
    "tsBuildInfoFile": "./.ts-out/.tsbuildinfo",
    "paths": {
      "*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "effect-sql-kit": ["../effect-sql-kit/src/index.ts"],
      "effect-sql-schema": ["../effect-sql-schema/src/index.mts"],
      "effect-sql-schema/*": ["../effect-sql-schema/src/*"],
      "effect-zero": ["../effect-zero/src/index.ts"],
      "sheet-models": ["../sheet-models/src/index.ts"],
      "typhoon-core": ["../typhoon-core/src/index.ts"],
      "typhoon-core/*": ["../typhoon-core/src/*"],
      "typhoon-zero": ["../typhoon-zero/src/index.ts"],
      "typhoon-zero/*": ["../typhoon-zero/src/*"]
    }
  },
  "references": [
    {
      "path": "../effect-sql-kit"
    },
    {
      "path": "../effect-sql-schema"
    },
    {
      "path": "../effect-zero"
    },
    {
      "path": "../sheet-models"
    },
    {
      "path": "../typhoon-core"
    },
    {
      "path": "../typhoon-zero"
    },
    {
      "path": "../tooling-config"
    }
  ]
}
