{
  "extends": "../../tsconfig.base.json",
  "files": [],
  "exclude": ["node_modules", "dist", ".output", ".ts-out"],
  "compilerOptions": {
    "outDir": "./.ts-out",
    "rootDir": ".",
    "tsBuildInfoFile": "./.ts-out/.tsbuildinfo",
    "noEmit": true,
    "emitDeclarationOnly": false,
    "paths": {
      "*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"]
    }
  }
}
