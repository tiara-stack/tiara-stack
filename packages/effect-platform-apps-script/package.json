{
  "name": "effect-platform-apps-script",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "",
  "files": [
    "./dist/**"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*/index.d.mts",
      "default": "./dist/*/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "vp lint src",
    "check:effect-lsp": "NODE_OPTIONS='--max-old-space-size=4096' effect-language-service diagnostics --project tsconfig.json --format text --lspconfig '{}'",
    "build": "vp pack"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/google-apps-script": "^1.0.99",
    "@typescript/native-preview": "latest",
    "glob": "^11.0.1",
    "pathe": "^2.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
