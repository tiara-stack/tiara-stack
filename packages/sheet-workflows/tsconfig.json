{
  "include": ["**/*.ts", "**/*.tsx", "*.ts", "*.tsx"],
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "sheet-auth/client": ["../sheet-auth/src/client.ts"],
      "sheet-auth/oauth": ["../sheet-auth/src/oauth.ts"],
      "sheet-auth/oauth-resource-authorization": [
        "../sheet-auth/src/oauth-resource-authorization.ts"
      ],
      "sheet-ingress-api/*": ["../sheet-ingress-api/src/*"],
      "*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "~/*": ["./src/*"],
      "@/*": ["./src/*"]
    }
  }
}
