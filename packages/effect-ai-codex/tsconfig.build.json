{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": ".ts-out",
    "tsBuildInfoFile": ".ts-out/.tsbuildinfo"
  },
  "exclude": [
    "node_modules",
    "dist",
    ".output",
    ".ts-out",
    ".tsbuildinfo",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
