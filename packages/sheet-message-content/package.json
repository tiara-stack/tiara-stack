{
  "name": "sheet-message-content",
  "version": "0.0.0",
  "private": true,
  "files": [
    "./dist/**"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "vp lint src",
    "test": "vp test run",
    "test:watch": "vp test",
    "build": "vp pack && tar -acf dist.tar.zst ./dist"
  },
  "dependencies": {
    "sheet-ingress-api": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "tooling-config": "workspace:*",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
