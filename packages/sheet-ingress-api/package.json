{
  "name": "sheet-ingress-api",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "",
  "files": [
    "./dist/**"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./api": {
      "types": "./dist/api.d.mts",
      "default": "./dist/api.mjs"
    },
    "./clientActions": {
      "types": "./dist/clientActions.d.mts",
      "default": "./dist/clientActions.mjs"
    },
    "./tokenCache": {
      "types": "./dist/tokenCache.d.mts",
      "default": "./dist/tokenCache.mjs"
    },
    "./api-groups": {
      "types": "./dist/api-groups.d.mts",
      "default": "./dist/api-groups.mjs"
    },
    "./handlers/health/schema": {
      "types": "./dist/handlers/health/schema.d.mts",
      "default": "./dist/handlers/health/schema.mjs"
    },
    "./handlers/clientDelivery/api": {
      "types": "./dist/handlers/clientDelivery/api.d.mts",
      "default": "./dist/handlers/clientDelivery/api.mjs"
    },
    "./handlers/dispatch/schema": {
      "types": "./dist/handlers/dispatch/schema.d.mts",
      "default": "./dist/handlers/dispatch/schema.mjs"
    },
    "./internal": {
      "types": "./dist/internal.d.mts",
      "default": "./dist/internal.mjs"
    },
    "./sheet-apis": {
      "types": "./dist/sheet-apis.d.mts",
      "default": "./dist/sheet-apis.mjs"
    },
    "./sheet-apis-rpc": {
      "types": "./dist/sheet-apis-rpc.d.mts",
      "default": "./dist/sheet-apis-rpc.mjs"
    },
    "./sheet-workflows": {
      "types": "./dist/sheet-workflows.d.mts",
      "default": "./dist/sheet-workflows.mjs"
    },
    "./sheet-workflows-rpc": {
      "types": "./dist/sheet-workflows-rpc.d.mts",
      "default": "./dist/sheet-workflows-rpc.mjs"
    },
    "./sheet-workflows-workflows": {
      "types": "./dist/sheet-workflows-workflows.d.mts",
      "default": "./dist/sheet-workflows-workflows.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.mts",
      "default": "./dist/schemas.mjs"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.mts",
      "default": "./dist/schemas/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "vp lint src",
    "test": "vp test run",
    "test:watch": "vp test",
    "build": "vp pack && tar -acf dist.tar.zst ./dist"
  },
  "dependencies": {
    "dfx-discord-utils": "workspace:*",
    "sheet-models": "workspace:*",
    "typhoon-core": "workspace:*",
    "typhoon-zero": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
