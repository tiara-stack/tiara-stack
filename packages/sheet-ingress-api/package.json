{
  "name": "sheet-ingress-api",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "",
  "files": [
    "./dist/**"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./api": {
      "types": "./dist/api.d.mts",
      "default": "./dist/api.mjs"
    },
    "./discordComponents": {
      "types": "./dist/discordComponents.d.mts",
      "default": "./dist/discordComponents.mjs"
    },
    "./api-groups": {
      "types": "./dist/api-groups.d.mts",
      "default": "./dist/api-groups.mjs"
    },
    "./handlers/health/schema": {
      "types": "./dist/handlers/health/schema.d.mts",
      "default": "./dist/handlers/health/schema.mjs"
    },
    "./middlewares/sheetAuthTokenAuthorization/tag": {
      "types": "./dist/middlewares/sheetAuthTokenAuthorization/tag.d.mts",
      "default": "./dist/middlewares/sheetAuthTokenAuthorization/tag.mjs"
    },
    "./middlewares/forwardedAuthHeaders": {
      "types": "./dist/middlewares/forwardedAuthHeaders.d.mts",
      "development": "./src/middlewares/forwardedAuthHeaders.ts",
      "default": "./dist/middlewares/forwardedAuthHeaders.mjs"
    },
    "./middlewares/sheetApisRpcAuthorization/tag": {
      "types": "./dist/middlewares/sheetApisRpcAuthorization/tag.d.mts",
      "default": "./dist/middlewares/sheetApisRpcAuthorization/tag.mjs"
    },
    "./middlewares/sheetBotServiceAuthorization/tag": {
      "types": "./dist/middlewares/sheetBotServiceAuthorization/tag.d.mts",
      "default": "./dist/middlewares/sheetBotServiceAuthorization/tag.mjs"
    },
    "./middlewares/sheetApisServiceUserFallback/tag": {
      "types": "./dist/middlewares/sheetApisServiceUserFallback/tag.d.mts",
      "default": "./dist/middlewares/sheetApisServiceUserFallback/tag.mjs"
    },
    "./middlewares/sheetApisAnonymousUserFallback/tag": {
      "types": "./dist/middlewares/sheetApisAnonymousUserFallback/tag.d.mts",
      "default": "./dist/middlewares/sheetApisAnonymousUserFallback/tag.mjs"
    },
    "./sheet-apis": {
      "types": "./dist/sheet-apis.d.mts",
      "default": "./dist/sheet-apis.mjs"
    },
    "./sheet-apis-rpc": {
      "types": "./dist/sheet-apis-rpc.d.mts",
      "default": "./dist/sheet-apis-rpc.mjs"
    },
    "./sheet-workflows": {
      "types": "./dist/sheet-workflows.d.mts",
      "default": "./dist/sheet-workflows.mjs"
    },
    "./sheet-workflows-rpc": {
      "types": "./dist/sheet-workflows-rpc.d.mts",
      "default": "./dist/sheet-workflows-rpc.mjs"
    },
    "./sheet-workflows-workflows": {
      "types": "./dist/sheet-workflows-workflows.d.mts",
      "default": "./dist/sheet-workflows-workflows.mjs"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.mts",
      "default": "./dist/schemas/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "vp lint src",
    "test": "vp test run",
    "test:watch": "vp test",
    "build": "vp pack && tar -acf dist.tar.zst ./dist"
  },
  "dependencies": {
    "dfx-discord-utils": "workspace:*",
    "effect-sql-schema": "workspace:*",
    "sheet-db-schema": "workspace:*",
    "typhoon-core": "workspace:*",
    "typhoon-zero": "workspace:*"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260327.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
