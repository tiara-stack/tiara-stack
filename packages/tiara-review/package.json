{
  "name": "tiara-review",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "",
  "bin": {
    "tiara-review": "./dist/index.mjs"
  },
  "files": [
    "./dist/**"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "vp lint src",
    "pretest": "pnpm --filter effect-ai-codex build && pnpm --filter effect-ai-kimi build",
    "test": "vp test run && node --import tsx scripts/smoke-source-child.mjs && pnpm build && node scripts/smoke-dist-worker.mjs",
    "test:dist-worker": "node scripts/smoke-dist-worker.mjs",
    "build": "vp pack"
  },
  "dependencies": {
    "@effect/ai-openai": "catalog:",
    "@effect/ai-openrouter": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql-sqlite-node": "catalog:",
    "effect": "catalog:",
    "effect-ai-codex": "workspace:*",
    "effect-ai-kimi": "workspace:*",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "tooling-config": "workspace:*",
    "tsx": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
