{
  "extends": "../../tsconfig.browser.json",
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts"],
  "exclude": ["node_modules", "dist", ".output", ".ts-out"],
  "compilerOptions": {
    "outDir": "./.ts-out",
    "rootDir": ".",
    "tsBuildInfoFile": "./.ts-out/.tsbuildinfo",
    "paths": {
      "*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "effect-ai-codex": ["../effect-ai-codex/src/index.ts"],
      "effect-ai-kimi": ["../effect-ai-kimi/src/index.ts"]
    }
  },
  "references": [
    {
      "path": "../effect-ai-codex"
    },
    {
      "path": "../effect-ai-kimi"
    },
    {
      "path": "../tooling-config"
    }
  ]
}
