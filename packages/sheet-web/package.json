{
  "name": "sheet-web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "format": "vp fmt --check",
    "format:apply": "vp fmt",
    "lint": "pnpm docs:generate && vp lint src",
    "test": "vp test run",
    "test:watch": "vp test",
    "dev": "vp dev --port 3001",
    "docs:generate": "fumadocs-mdx",
    "docs:search:export": "tsx scripts/index-docs-search.ts --output=.output/server/docs-search-manifest.json",
    "docs:search:bundle": "esbuild scripts/run-docs-search-index.ts --bundle --platform=node --format=esm --target=node22 --outfile=.output/server/docs-search-index.mjs",
    "docs:search:index": "node .output/server/docs-search-index.mjs --mode=incremental",
    "docs:search:index:full": "node .output/server/docs-search-index.mjs --mode=full",
    "build": "pnpm docs:generate && vp build && pnpm docs:search:export && pnpm docs:search:bundle && tar -acf dist.tar.zst ./.output",
    "preview": "vp preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@effect/atom-react": "catalog:",
    "@effect/platform-node": "catalog:",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.19",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "effect": "catalog:",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "16.11.5",
    "lucide-react": "^0.561.0",
    "meilisearch": "0.59.0",
    "motion": "^12.35.1",
    "nitro": "npm:nitro-nightly@latest",
    "react": "19.3.0-canary-98ce535f-20260226",
    "react-dom": "19.3.0-canary-98ce535f-20260226",
    "sheet-auth": "workspace:*",
    "sheet-ingress-api": "workspace:*",
    "start-atom": "workspace:*",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.3.6",
    "typhoon-core": "workspace:*",
    "typhoon-zero": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/mdx": "2.0.14",
    "@types/node": "catalog:",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "0.28.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^27.0.0",
    "tooling-config": "workspace:*",
    "tsx": "4.22.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
