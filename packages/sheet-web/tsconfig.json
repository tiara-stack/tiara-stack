{
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", ".output", ".tsbuildinfo"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "sheet-auth": ["../sheet-auth/src/index.ts"],
      "sheet-auth/*": ["../sheet-auth/src/*"],
      "sheet-ingress-api": ["../sheet-ingress-api/src/index.ts"],
      "sheet-ingress-api/*": ["../sheet-ingress-api/src/*"],
      "*": ["./*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "~/*": ["./src/*"],
      "@/*": ["./src/*"],
      "#/*": ["./src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "react/canary"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
